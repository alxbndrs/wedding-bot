# {{ ansible_managed }}
[Unit]
Description=Wedding slot watcher — poll booking site and alert on Telegram
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=%h/.config/weddingbot.env
# flock prevents a slow run from overlapping the next minute's trigger.
ExecStart=/usr/bin/flock -n %h/state/run.lock /usr/bin/python3 %h/bin/wedding_bot.py
Nice=-5
