# {{ ansible_managed }}
# Loaded by the systemd units (EnvironmentFile) and by --test-notify/--test-call.
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_chat_id }}

# Twilio phone call (optional — blank values disable the call, Telegram-only).
TWILIO_ACCOUNT_SID={{ twilio_account_sid | default('') }}
TWILIO_AUTH_TOKEN={{ twilio_auth_token | default('') }}
TWILIO_FROM={{ twilio_from | default('') }}
CALL_TO={{ call_to | default('') }}

START_URL={{ weddingbot_start_url }}
BOOKING_URL={{ weddingbot_booking_url }}

STATE_FILE={{ weddingbot_account.home }}/state/state.json
LOG_FILE={{ weddingbot_account.home }}/state/weddingbot.log

RENOTIFY_MINUTES={{ weddingbot_renotify_minutes }}
FAILURE_ALERT_THRESHOLD={{ weddingbot_failure_alert_threshold }}
HTTP_TIMEOUT={{ weddingbot_http_timeout }}
