---
# Copy to host_vars/dev.yml (gitignored) and fill in real values.
#
# Connection details for the OVH server — reuse the SAME values you use in the
# Clispi/ovhcloud-server-setup repo's host_vars/dev.yml.
ansible_host: 203.0.113.10               # your server's IP or DNS name
ansible_ssh_private_key_file: ~/.ssh/id_rsa

# Telegram bot credentials (see README for how to get these).
telegram_bot_token: "1234567890:AAExampleExampleExampleExampleExample"
telegram_chat_id: "123456789"

# Twilio phone-call alert (OPTIONAL — leave blank to disable the call and use
# Telegram only). When all four are set, a slot-found also rings your phone and
# reads a spoken alert. See README for where to find these in the Twilio console.
twilio_account_sid: ""                    # "ACxxxxxxxx..."
twilio_auth_token: ""                     # your Twilio auth token
twilio_from: ""                           # your Twilio number, E.164 e.g. "+45..."
call_to: ""                               # number to ring, E.164 e.g. "+4520123456"
